# ================= SERVER =================
PORT=3000
NODE_ENV=production
API_PREFIX=/api/v1

# ================= DATABASE MySQL =================
# ⚠️ GANTI DENGAN KREDENSIAL DARI PROVIDER HOSTING-MU
DB_HOST=your-db-host.com          # Contoh: mysql.hostinger.com / containers-us-west.railway.app
DB_PORT=3306
DB_NAME=db_nusa_grow_prod         # Nama database di hosting
DB_USER=u123456_nusagrow          # Username database (jangan pakai 'root' di production)
DB_PASSWORD=Kx9#mP2$vLq!8zR       # Password kuat dari provider
DB_DIALECT=mysql

# Pooling (opsional, bisa disesuaikan)
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ================= JWT Auth =================
JWT_SECRET=production-jwt-key-min-32-char-secure-random-2026!  # Ganti dengan random string 32+ karakter
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ================= Payment Gateway (Midtrans) =================
PAYMENT_PROVIDER=midtrans
MIDTRANS_SERVER_KEY=Mid-server-xxx-production     # Ganti dengan key production Midtrans
MIDTRANS_CLIENT_KEY=Mid-client-xxx-production
MIDTRANS_IS_PRODUCTION=true                        # Ubah ke true untuk live

# ================= Maps & Location =================
GOOGLE_MAPS_API_KEY=AIzaSyD-xxx-your-real-key       # Ganti dengan API key Google Maps-mu
DEFAULT_RADIUS_KM=50

# ================= File Upload =================
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./public/uploads

# ================= CORS =================
# ⚠️ Hanya izinkan domain yang sah
CORS_ORIGIN=https://nusagrow.netlify.app/

# ================= LOGGING & DEBUG =================
LOG_LEVEL=info
ENABLE_DEBUG=false