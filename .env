# ================= SERVER =================
PORT=3000
NODE_ENV=production
API_PREFIX=/api/v1

# ================= DATABASE MySQL (Railway) =================
# ⚠️ Di Railway, variabel ini TIDAK diisi manual di file .env
#    Tapi di-set via Dashboard Railway → Variables → Reference ke MySQL Service
#    Format: DB_HOST=${{MYSQL.MYSQLHOST}} (pilih dari dropdown)
#
# Untuk local development, gunakan nilai localhost:
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_nusa_grow
DB_USER=root
DB_PASSWORD=
DB_DIALECT=mysql

# Pooling
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ================= JWT Auth =================
JWT_SECRET=production-jwt-key-min-32-char-secure-random-2026!
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ================= Payment Gateway (Midtrans) =================
PAYMENT_PROVIDER=midtrans
MIDTRANS_SERVER_KEY=SB-Mid-server-xxx          # Sandbox key (ganti ke production key jika live)
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxx
MIDTRANS_IS_PRODUCTION=false                   # Ubah ke true hanya jika sudah live

# ================= Maps & Location =================
GOOGLE_MAPS_API_KEY=AIzaSyD-xxx-your-real-key
DEFAULT_RADIUS_KM=50

# ================= File Upload =================
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./public/uploads

# ================= CORS =================
# ⚠️ Di Railway, tambahkan domain Railway + Netlify
CORS_ORIGIN=https://nusagrow.netlify.app,http://localhost:3000

# ================= LOGGING & DEBUG =================
LOG_LEVEL=info
ENABLE_DEBUG=false